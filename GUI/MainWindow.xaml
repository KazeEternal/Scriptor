<Window x:Class="GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="Scriptor" Height="1080" Width="1920">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>
        <Menu x:Name="menu" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"/>
        <ToolBarPanel x:Name="toolBar" VerticalAlignment="Top" 
                 Width="100"
                 Grid.Row="1" 
                 Grid.Column="0"
                 Grid.ColumnSpan="3">
        </ToolBarPanel>
        <TreeView Grid.RowSpan="2" Grid.Row="2" Grid.Column="0">
            


        </TreeView>
        <DataGrid Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2">
            
        </DataGrid>
    </Grid>
</Window>
